{% block activite_progressions_by_activite_display_widget %}
    {% set activite = form.parent.vars.data %}
    {% if activite and activite.activiteProgressions is not empty %}
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>Élève</th>
                    <th>Complété le</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for ap in activite.activiteProgressions %}
                    <tr>
                        <td>
                            <a href="{{ crud_url('EleveCrudController', 'detail', ap.eleve.id) }}" class="text-decoration-none">
                                {{ ap.eleve }}
                            </a>
                        </td>
                        <td>
                            {% if ap.completedAt %}
                                {{ ap.completedAt|date('d/m/Y H:i') }}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ crud_url('ActiviteProgressionCrudController', 'detail', ap.id) }}" class="text-decoration-none text-muted small">Voir</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <em class="text-muted">Aucune progression</em>
    {% endif %}
{% endblock %}
