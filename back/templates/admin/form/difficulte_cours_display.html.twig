{% block difficulte_cours_display_widget %}
    {% set difficulte = form.parent.vars.data %}
    {% if difficulte and difficulte.cours is not empty %}
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>Cours</th>
                    <th>Professeur</th>
                    <th>Matière</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for cour in difficulte.cours %}
                    <tr>
                        <td>{{ cour }}</td>
                        <td>
                            <a href="{{ crud_url('ProfesseurCrudController', 'detail', cour.professeur.id) }}" class="text-decoration-none">
                                {{ cour.professeur }}
                            </a>
                        </td>
                        <td>{{ cour.matiere }}</td>
                        <td>
                            <a href="{{ crud_url('CoursCrudController', 'detail', cour.id) }}" class="text-decoration-none text-muted small">Voir</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <em class="text-muted">Aucun cours</em>
    {% endif %}
{% endblock %}
